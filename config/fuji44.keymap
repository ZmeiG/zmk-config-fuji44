#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    combos {
        compatible = "zmk,combos";

        combo_esc {
            timeout-ms = <50>;
            key-positions = <0 1>;
            bindings = <&kp ESC>;
        };

        ru_en {
            bindings = <&kp LC(LA(SPACE))>;
            key-positions = <24 25>;
        };
    };

    behaviors {
        ss_hs_modmorph: ss_hs_modmorph {
            compatible = "zmk,behavior-mod-morph";
            label = "SS_HS_MODMORPH";
            bindings = <&kp M>, <&kp RIGHT_BRACKET>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        kh_hs_tapdance: kh_hs_tapdance {
            compatible = "zmk,behavior-tap-dance";
            label = "KH_HS_TAPDANCE";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp LEFT_BRACKET>, <&kp RIGHT_BRACKET>;
        };

        hrm: hrm {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <125>;
            bindings = <&kp>, <&kp>;
        };

        hml: home_row_mod_left {
            compatible = "zmk,behavior-hold-tap";
            label = "HML";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <250>;
            quick-tap-ms = <165>;
            require-prior-idle-ms = <130>;
            flavor = "tap-preferred";
            hold-trigger-key-positions = <30 31 32 33 34 35 23 11 10 22 21 9 8 19 7 6 18 20 30 31 32 33 40 41 42 43>;
            hold-trigger-on-release;
        };

        hmr: home_row_mod_right {
            compatible = "zmk,behavior-hold-tap";
            label = "HMR";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <250>;
            quick-tap-ms = <165>;
            require-prior-idle-ms = <130>;
            flavor = "tap-preferred";
            hold-trigger-on-release;
            hold-trigger-key-positions = <0 1 2 3 4 5 12 13 14 15 16 17 24 25 26 27 28 29 36 37 38 39>;
        };

        bh_fwslsl_lftbrckt: bh_fwslsl_lftbrckt {
            compatible = "zmk,behavior-mod-morph";
            label = "BH_FWSLSL_LFTBRCKT";
            bindings = <&kp FSLH>, <&kp LEFT_BRACKET>;

            #binding-cells = <0>;
            mods = <(MOD_RALT)>;
        };

        bh_bckslsh_rghtbrckt: bh_bckslsh_rghtbrckt {
            compatible = "zmk,behavior-mod-morph";
            label = "BH_BCKSLSH_RGHTBRCKT";
            bindings = <&kp FSLH>, <&kp RIGHT_BRACKET>;

            #binding-cells = <0>;
            mods = <(MOD_RALT)>;
        };

        bh_bcksp_del: bh_bcksp_del {
            compatible = "zmk,behavior-mod-morph";
            label = "BH_BCKSP_DEL";
            bindings = <&kp BACKSPACE>, <&kp DELETE>;

            #binding-cells = <0>;
            mods = <(MOD_RALT)>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        def {
            bindings = <
&kp ESC    &kp Q  &kp W             &kp E         &kp R         &kp T          &kp Y        &kp U  &kp I                  &kp O              &kp P     &bh_bcksp_del
&kp TAB    &kp A  &kp S             &kp D         &kp F         &kp G          &kp H        &kp J  &kp K                  &kp L              &kp SEMI  &kp SQT
&kp LSHFT  &kp Z  &kp X             &kp C         &kp V         &kp B          &kp N        &kp M  &kp COMMA              &kp DOT            &kp FSLH  &kp BACKSLASH
                  &kp LEFT_CONTROL  &kp LEFT_ALT  &kp LEFT_GUI  &lt 1 SPACE    &lt 3 ENTER  &mo 2  &mt RALT LEFT_BRACKET  &kp RIGHT_BRACKET
            >;
        };

        nav {
            bindings = <
&trans  &kp GRAVE  &kp UNDERSCORE  &trans    &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS    &kp PAGE_UP    &kp HOME        &kp UP_ARROW    &kp END    &kp INS       &trans
&trans  &kp EQUAL  &kp MINUS       &kp PLUS  &kp LEFT_BRACKET      &kp RIGHT_BRACKET        &kp PAGE_DOWN  &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT  &kp CAPSLOCK  &trans
&trans  &trans     &trans          &trans    &kp LEFT_BRACE        &kp RIGHT_BRACE          &kp PSCRN      &kp LC(LEFT)    &kp LC(RIGHT)   &kp LT     &kp GT        &trans
                   &trans          &trans    &trans                &trans                   &trans         &trans          &trans          &trans
            >;
        };

        num {
            bindings = <
&trans  &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp NUMBER_4  &kp NUMBER_5    &kp F1  &kp F2  &kp F3  &kp F4   &kp F5   &kp F6
&trans  &kp N6        &kp NUMBER_7  &kp NUMBER_8  &kp NUMBER_9  &kp NUMBER_0    &kp F7  &kp F8  &kp F9  &kp F10  &kp F11  &kp F12
&trans  &trans        &trans        &trans        &trans        &trans          &trans  &trans  &trans  &trans   &trans   &trans
                      &trans        &trans        &trans        &trans          &trans  &trans  &trans  &trans
            >;

            label = "Num_Lr";
        };

        sym {
            bindings = <
&trans  &kp EXCL   &kp AT_SIGN  &kp HASH  &kp DOLLAR  &kp PERCENT    &trans  &trans      &trans     &trans        &trans         &trans
&trans  &kp CARET  &kp AMPS     &kp STAR  &kp LPAR    &kp RPAR       &trans  &kp RSHIFT  &kp RCTRL  &kp LEFT_ALT  &kp RIGHT_WIN  &trans
&trans  &trans     &trans       &trans    &trans      &trans         &trans  &trans      &trans     &trans        &trans         &trans
                   &trans       &trans    &trans      &trans         &trans  &trans      &trans     &trans
            >;
        };

        sys {
            bindings = <
&bootloader  &trans  &trans  &trans  &trans  &trans    &trans  &bt BT_CLR    &bt BT_CLR_ALL  &trans        &trans        &bootloader
&trans       &trans  &trans  &trans  &trans  &trans    &trans  &trans        &trans          &trans        &trans        &trans
&sys_reset   &trans  &trans  &trans  &trans  &trans    &trans  &bt BT_SEL 0  &bt BT_SEL 1    &bt BT_SEL 2  &bt BT_SEL 3  &sys_reset
                     &trans  &trans  &trans  &trans    &trans  &trans        &trans          &trans
            >;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        sys_lr {
            if-layers = <1 2>;
            then-layer = <4>;
        };
    };
};